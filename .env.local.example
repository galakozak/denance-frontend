######################################################
# DEFUSE FRONTEND - LOCAL DEVELOPMENT CONFIGURATION #
######################################################
#
# Copy this file to .env.local and fill in the values.
# Variables marked with [REQUIRED] are necessary for basic functionality.
# Variables marked with [OPTIONAL] enhance features but aren't critical for development.
# Variables marked with [EXTERNAL] require external service setup.
#

######################################################
# CORE DATABASE & BACKEND SERVICES                  #
######################################################

# [REQUIRED] Supabase Configuration
# Get these from your local Supabase instance (supabase start) or remote project
SUPABASE_URL="http://127.0.0.1:54321"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# [OPTIONAL] Legacy Forwarder Supabase (if using separate instance)
FORWARDER_SUPABASE_URL=""
FORWARDER_SUPABASE_SERVICE_KEY=""

# [OPTIONAL] ClickHouse Database for Analytics
# For local development, you can leave these empty to disable analytics
# Format: http://localhost:8123 or https://your-clickhouse-instance.com
CLICKHOUSE_SERVICE_URL=""
CLICKHOUSE_API_KEY=""
# Alternative ClickHouse configuration (used in some parts of the codebase)
CLICK_HOUSE_URL=""
CLICK_HOUSE_USERNAME=""
CLICK_HOUSE_PASSWORD=""

######################################################
# BLOCKCHAIN & WEB3 CONFIGURATION                   #
######################################################

# [REQUIRED] NEAR Protocol Configuration
# For mainnet: https://rpc.mainnet.near.org
# For testnet: https://rpc.testnet.near.org
NEAR_NODE_URL="https://rpc.testnet.near.org"
NEAR_ENV="testnet"

# [OPTIONAL] Solana RPC URL
# For local development: http://127.0.0.1:8899
# For devnet: https://api.devnet.solana.com
SOLANA_RPC_URL="https://api.devnet.solana.com"

# [EXTERNAL] WalletConnect Project ID
# Get from https://cloud.walletconnect.com/
# Required for wallet connection functionality
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=""

######################################################
# EXTERNAL API KEYS                                 #
######################################################

# [EXTERNAL] CoinGecko API for token prices
# Get from https://www.coingecko.com/api/pricing
# Can leave empty for basic functionality (prices may not work)
COINGECKO_API_KEY=""

# [EXTERNAL] Mixpanel Analytics
# Get from https://mixpanel.com/
# Leave empty to disable analytics tracking
NEXT_PUBLIC_MIXPANEL_TOKEN=""

# [EXTERNAL] HelpScout Customer Support
# Get from https://helpscout.com/
# Leave empty to disable support widget
NEXT_PUBLIC_HELPSCOUT_BEACON_ID=""

######################################################
# AUTHENTICATION & SECURITY                         #
######################################################

# [REQUIRED] JWT Secret for authentication
# Generate with: openssl rand -hex 32
AUTH_JWT_SECRET="your-jwt-secret-here"

# [OPTIONAL] JWT Public Key for API integrations
# Only needed if using API integrations
JWT_PUBLIC_KEY=""

# [REQUIRED] Cron job secret for scheduled tasks
# Generate with: openssl rand -hex 16
CRON_SECRET="your-cron-secret-here"

######################################################
# MONITORING & DEBUGGING                            #
######################################################

# [OPTIONAL] Sentry Error Tracking
# Set to "true" to enable Sentry in development
# Get DSN from https://sentry.io/
NEXT_PUBLIC_SENTRY_ENABLED="false"

######################################################
# APPLICATION CONFIGURATION                         #
######################################################

# [OPTIONAL] Application URLs and Links
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
APP_URL="/"
NEXT_PUBLIC_LINK_DOCS=""
NEXT_PUBLIC_PUBLIC_MAIL=""
NEXT_PUBLIC_PUBLIC_TG=""

# [OPTIONAL] Social Media Links
SOCIAL_LINK_X=""
SOCIAL_LINK_DISCORD=""
LINK_DOCS=""

# [OPTIONAL] Development Flags
# Set to "true" to enable development mode features
NEXT_PUBLIC_DEV_MODE="true"
# Set to "true" to disable certain app features during development
TURN_OFF_APPS="false"
# Environment for intents: "production" or "stage"
NEXT_PUBLIC_INTENTS_ENV="stage"

######################################################
# QUICK START MINIMAL CONFIGURATION                 #
######################################################
#
# For a minimal working setup, you only need:
# 1. Set up Supabase locally: `supabase start`
# 2. Copy the URL and service role key from the output
# 3. Generate secrets for AUTH_JWT_SECRET and CRON_SECRET
# 4. Set NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID for wallet functionality
#
# Example minimal config:
# SUPABASE_URL="http://127.0.0.1:54321"
# SUPABASE_SERVICE_ROLE_KEY="your-key-from-supabase-start"
# AUTH_JWT_SECRET="generated-with-openssl-rand-hex-32"
# CRON_SECRET="generated-with-openssl-rand-hex-16"
# NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID="your-project-id"
#

######################################################
# AUTOMATIC SYSTEM VARIABLES (DO NOT SET MANUALLY)  #
######################################################
#
# These variables are automatically set by Next.js/Vercel:
# - NODE_ENV (development/production)
# - NEXT_RUNTIME (nodejs/edge)
# - VERCEL_PROJECT_PRODUCTION_URL (Vercel deployment URL)
# - VERCEL_URL (Current deployment URL)
#
